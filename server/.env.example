# Copy this file to .env and fill in the values for your environment.
# Never commit .env — it is listed in .gitignore.

# Server
PORT=3000
# HOST defaults to 0.0.0.0 (required on Render); omit for local dev

# PostgreSQL — full connection string including credentials
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/extriviate

# JWT signing secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_before_production

# Redis — optional. If omitted, token revocation (logout) is a no-op.
# Tokens still expire naturally (access: 15m, refresh: 7d).
REDIS_URL=

# Cloudflare Turnstile keys (for captcha purposes)
CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=

# Cloudflare R2 object storage (required for file uploads)
R2_ACCOUNT_ID=
R2_ACCOUNT_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Resend email server (required for password reset, account recovery emails)
RESEND_API_KEY=

# Angular dev server origin — only needed in local development
CLIENT_URL=http://localhost:4200
