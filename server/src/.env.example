# Copy this to .env and fill in your values
# .env is gitignored - this file is committed as documentation

PORT=3000
HOST=0.0.0.0
NODE_ENV=development

DATABASE_URL=postgresql://postgres:password@localhost:5432/extriviate_dev
REDIS_URL=redis://localhost:6379

JWT_SECRET=change_this_to_a_long_random_string_before_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=extriviate-uploads
R2_PUBLIC_BASE_URL=https://pub-YOURHASH.r2.dev

CLIENT_URL=http://localhost:4200